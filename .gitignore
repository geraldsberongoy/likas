# Dependency directories
node_modules/

# Build artifacts
android/app/build/
android/.gradle/
ios/build/
ios/DerivedData/
ios/Pods/
ios/.xcode.env.local

# Models and large assets (placeholders)
*.litertlm
*.bin
*.gguf
*.mbtiles
*.osm.pbf
planetiler.jar

# Generated large map data
Likas/assets/maps/*.db
Likas/assets/maps/*.json

# OS-specific
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.iml
*.swp
*.swo

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Generated native assets
Likas/android/app/src/main/assets/custom/
Likas/android/app/src/main/assets/fonts/
Likas/android/app/src/main/assets/glyphs/

# --- Asset Rules ---
Likas/assets/glyphs/
Likas/assets/data/
Likas/data/
scripts/assets/
Likas/src/data/scraped/

# Big data files to keep out of Git
**/*Flood_100year.json

# Allow small JSONs (Un-ignore patterns)
!Likas/assets/data/*.json
!Likas/assets/data/**/*.json
!Likas/src/data/*.json
!Likas/src/data/scraped/*.json

# Allow specific code files
!Likas/src/data/*.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Android/Gradle Build Artifacts
**/.gradle/
**/android/build/
**/android/app/build/
**/android/app/.cxx/
**/local.properties
**/*.iml
*.keystore
debug.keystore
